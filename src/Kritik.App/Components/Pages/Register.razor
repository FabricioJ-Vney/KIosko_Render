@page "/register"
@inject Kritik.App.Services.AuthService AuthService
@inject NavigationManager NavigationManager
@inject Kritik.App.Services.ToastService ToastService

<h3>Crear Cuenta</h3>

<div class="card p-4 mx-auto" style="max-width: 450px;">
    <EditForm Model="@registerModel" OnValidSubmit="HandleRegister">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label for="fullName" class="form-label">Nombre Completo</label>
            <InputText id="fullName" class="form-control" @bind-Value="registerModel.FullName" />
        </div>

        <div class="mb-3">
            <label for="username" class="form-label">Correo / Usuario</label>
            <InputText id="username" class="form-control" @bind-Value="registerModel.Username" />
        </div>
        
        <div class="mb-3">
            <label for="password" class="form-label">Contraseña</label>
            <InputText id="password" type="password" class="form-control" @bind-Value="registerModel.Password" />
        </div>

        <div class="mb-4">
            <label class="form-label fw-bold">¿Qué eres en este evento?</label>
            <div class="d-flex gap-2">
                <div class="flex-grow-1 p-3 border rounded-3 text-center @(registerModel.Role == "Student" ? "border-warning bg-warning bg-opacity-10 shadow-sm" : "")" style="cursor: pointer;" @onclick='() => registerModel.Role = "Student"'>
                    <i class="bi bi-mortarboard fs-3 @(registerModel.Role == "Student" ? "text-warning" : "text-muted")"></i>
                    <div class="fw-bold mt-2">Estudiante</div>
                    <small class="text-muted d-block" style="font-size: 0.7rem;">Presentaré mi proyecto</small>
                </div>
                <div class="flex-grow-1 p-3 border rounded-3 text-center @(registerModel.Role == "Evaluator" ? "border-warning bg-warning bg-opacity-10 shadow-sm" : "")" style="cursor: pointer;" @onclick='() => registerModel.Role = "Evaluator"'>
                    <i class="bi bi-briefcase fs-3 @(registerModel.Role == "Evaluator" ? "text-warning" : "text-muted")"></i>
                    <div class="fw-bold mt-2">Evaluador</div>
                    <small class="text-muted d-block" style="font-size: 0.7rem;">Soy juez / sinodal</small>
                </div>
            </div>
        </div>

        <button type="submit" class="btn btn-primary w-100">Registrarse</button>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-3 mb-0">@errorMessage</div>
        }
    </EditForm>
</div>
<div class="mt-3 text-center">
    ¿Ya tienes cuenta? <a href="/login">Inicia Sesión aquí</a>
</div>

@code {
    private Kritik.Shared.Models.User registerModel = new() { Role = "Student" };
    private string? errorMessage;

    private async Task HandleRegister()
    {
        errorMessage = null;
        var success = await AuthService.RegisterAsync(registerModel);
        if (success)
        {
            Microsoft.Maui.Storage.Preferences.Default.Set("user_role", registerModel.Role);
            ToastService.Show("Cuenta creada exitosamente. Ahora puedes iniciar sesión.", "success");
            NavigationManager.NavigateTo("/login");
        }
        else
        {
            errorMessage = "Error al crear la cuenta. Intenta con otro correo o revisa la conexión.";
            ToastService.Show("Error al registrarse", "error");
        }
    }
}
