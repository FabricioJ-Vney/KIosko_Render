@page "/profile"
@using Kritik.Shared.Models
@using Kritik.App.Services
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject AuthService AuthService
@inject EvaluationService EvaluationService

<div class="p-4 no-scrollbar" style="max-height: 100vh; overflow-y: auto;">
    <div class="text-center mb-5 animate-slide-up">
        <div class="mx-auto shadow-lg d-flex align-items-center justify-content-center mb-3" 
             style="width: 100px; height: 100px; border-radius: 35px; background: linear-gradient(135deg, #FFC107 0%, #FFB300 100%); color: black; font-size: 2.5rem; font-weight: 800;">
            @(user?.FullName?.Substring(0, 1).ToUpper() ?? "U")
        </div>
        <h2 class="fw-bold mb-1">@(user?.FullName ?? "Innovador")</h2>
        <span class="badge bg-dark rounded-pill px-3 py-2">@(user?.Role == "Evaluator" ? "Juez Oficial" : "Participante")</span>
    </div>

    <div class="row g-3 animate-slide-up" style="animation-delay: 0.1s;">
        <div class="col-6">
            <div class="glass-card p-3 text-center h-100" style="border-radius: 24px;">
                <div class="text-warning mb-2"><i class="bi bi-star-fill fs-3"></i></div>
                <div class="h3 fw-bold m-0">@evaluationCount</div>
                <small class="text-muted">Aportes</small>
            </div>
        </div>
        <div class="col-6">
            <div class="glass-card p-3 text-center h-100" style="border-radius: 24px;">
                <div class="text-info mb-2"><i class="bi bi-lightning-charge-fill fs-3"></i></div>
                <div class="h3 fw-bold m-0">@((evaluationCount * 50))</div>
                <small class="text-muted">Puntos XP</small>
            </div>
        </div>
    </div>

    <div class="mt-5 animate-slide-up" style="animation-delay: 0.2s;">
        <h6 class="text-muted text-uppercase fw-bold small mb-3 px-2">Preferencias</h6>
        <div class="glass-card p-2" style="border-radius: 24px;">
            <div class="d-flex align-items-center justify-content-between p-3 border-bottom">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-light p-2 rounded-3"><i class="bi bi-moon-stars"></i></div>
                    <span class="fw-bold">Modo Oscuro</span>
                </div>
                <div class="form-check form-switch fs-4">
                    <input class="form-check-input" type="checkbox" checked="@isDarkMode" @onchange="ToggleTheme" />
                </div>
            </div>
            <div class="d-flex align-items-center justify-content-between p-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-light p-2 rounded-3"><i class="bi bi-bell"></i></div>
                    <span class="fw-bold">Notificaciones</span>
                </div>
                <div class="form-check form-switch fs-4">
                    <input class="form-check-input" type="checkbox" checked />
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5 pt-4">
        <button class="btn btn-outline-danger w-100 py-3 rounded-pill fw-bold border-2" @onclick="Logout">
            <i class="bi bi-box-arrow-right me-2"></i> Cerrar Sesión
        </button>
        <p class="text-center text-muted small mt-4">Kritik v2.1.0 Commercial Edition</p>
    </div>
</div>

@code {
    private User? user;
    private int evaluationCount = 0;
    private bool isDarkMode = false;

    protected override async Task OnInitializedAsync()
    {
        user = AuthService.GetCurrentUser();
        isDarkMode = Microsoft.Maui.Storage.Preferences.Default.Get("IsDarkMode", false);
        
        if (user != null)
        {
            var evals = await EvaluationService.GetEvaluationsAsync();
            evaluationCount = evals.Count(e => e.EvaluatorId == user.Id || e.EvaluatorId == user.Username);
        }
    }

    private async Task ToggleTheme(ChangeEventArgs e)
    {
        isDarkMode = (bool)e.Value!;
        Microsoft.Maui.Storage.Preferences.Default.Set("IsDarkMode", isDarkMode);
        await JSRuntime.InvokeVoidAsync("setTheme", isDarkMode ? "dark" : "light");
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        NavigationManager.NavigateTo("/", forceLoad: true);
    }
}
